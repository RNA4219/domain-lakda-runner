{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lakda.dev/schemas/target-manifest-v2.schema.json",
  "title": "Lakda security target manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestId",
    "targetClass",
    "status",
    "binding",
    "owner",
    "environment",
    "access",
    "scope",
    "safety",
    "privacy",
    "actionContracts",
    "settleProfile",
    "acceptance",
    "security"
  ],
  "properties": {
    "schemaVersion": {
      "const": "lakda/target-manifest/v2"
    },
    "manifestId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "targetClass": {
      "enum": [
        "crm-list",
        "commerce-card",
        "collaboration-workspace",
        "security-http"
      ]
    },
    "status": {
      "const": "ready"
    },
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetRevision",
        "configDigest"
      ],
      "properties": {
        "targetRevision": {
          "type": "string",
          "minLength": 1
        },
        "configDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        }
      }
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "baseUrlOrigin"
      ],
      "properties": {
        "name": {
          "const": "staging"
        },
        "baseUrlOrigin": {
          "type": "string",
          "pattern": "^https://[^/?#]+$"
        }
      }
    },
    "access": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approved",
        "authSource",
        "approvalEvidenceRef"
      ],
      "properties": {
        "approved": {
          "const": true
        },
        "authSource": {
          "enum": [
            "github-environment",
            "local-auth-state"
          ]
        },
        "approvalEvidenceRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowHosts",
        "pathPrefixes"
      ],
      "properties": {
        "allowHosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "pathPrefixes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^/"
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowMutationKinds",
        "resetProcedureRef",
        "killSwitchRef"
      ],
      "properties": {
        "allowMutationKinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "resetProcedureRef": {
          "type": "string",
          "minLength": 1
        },
        "killSwitchRef": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "piiPolicyRef",
        "sensitiveValuesPersisted"
      ],
      "properties": {
        "piiPolicyRef": {
          "type": "string",
          "minLength": 1
        },
        "sensitiveValuesPersisted": {
          "const": false
        }
      }
    },
    "actionContracts": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "actionId",
          "mutationKind"
        ],
        "properties": {
          "actionId": {
            "type": "string",
            "minLength": 1
          },
          "mutationKind": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "settleProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policyVersion",
        "networkQuietExclusions"
      ],
      "properties": {
        "policyVersion": {
          "type": "string",
          "minLength": 1
        },
        "readiness": {
          "type": [
            "object",
            "null"
          ]
        },
        "networkQuietExclusions": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^/"
          }
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "p0ActionIds",
        "p1ActionIds"
      ],
      "properties": {
        "p0ActionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "p1ActionIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptanceMode",
        "authorization",
        "requestScope",
        "limits",
        "dataPolicyRef",
        "stopContactRef",
        "securityProfile",
        "bridgeBinding"
      ],
      "properties": {
        "acceptanceMode": {
          "enum": [
            "deny-all",
            "authorized-active",
            "passive"
          ]
        },
        "authorization": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "authorizationId",
            "validFrom",
            "validUntil",
            "approvalEvidenceRef",
            "signatureRef",
            "signedPayloadDigest",
            "signature"
          ],
          "properties": {
            "authorizationId": {
              "type": "string",
              "minLength": 1
            },
            "validFrom": {
              "type": "string",
              "minLength": 1
            },
            "validUntil": {
              "type": "string",
              "minLength": 1
            },
            "approvalEvidenceRef": {
              "type": "string",
              "minLength": 1
            },
            "signatureRef": {
              "type": "string",
              "minLength": 1
            },
            "signedPayloadDigest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "signature": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "algorithm",
                "publicKeyPem",
                "valueBase64"
              ],
              "properties": {
                "algorithm": {
                  "const": "ed25519"
                },
                "publicKeyPem": {
                  "type": "string",
                  "pattern": "^-----BEGIN PUBLIC KEY-----"
                },
                "valueBase64": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9+/]+={0,2}$"
                }
              }
            }
          }
        },
        "requestScope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "methods",
            "requestTemplateDigests"
          ],
          "properties": {
            "methods": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[A-Z]+$"
              }
            },
            "requestTemplateDigests": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              }
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "maxRatePerMinute",
            "maxConcurrency"
          ],
          "properties": {
            "maxRatePerMinute": {
              "type": "integer",
              "minimum": 1
            },
            "maxConcurrency": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "dataPolicyRef": {
          "type": "string",
          "minLength": 1
        },
        "stopContactRef": {
          "type": "string",
          "minLength": 1
        },
        "securityProfile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ref",
            "digest"
          ],
          "properties": {
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "digest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        },
        "bridgeBinding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "capabilityDigest",
            "bridgeDigest"
          ],
          "properties": {
            "capabilityDigest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            },
            "bridgeDigest": {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          }
        }
      }
    }
  }
}

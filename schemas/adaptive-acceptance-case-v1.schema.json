{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lakda.dev/schemas/adaptive-acceptance-case-v1.schema.json",
  "title": "Lakda adaptive acceptance case report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "acceptanceId",
    "caseId",
    "runId",
    "attempt",
    "revision",
    "runnerRevision",
    "executionMode",
    "environment",
    "runtime",
    "seed",
    "configDigest",
    "corpus",
    "expected",
    "actual",
    "oracleResultRefs",
    "artifactRefs",
    "verdict",
    "ineligibilityReason",
    "qegHandoff",
    "generatedAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "lakda/adaptive-acceptance-case/v1"
    },
    "acceptanceId": {
      "type": "string",
      "pattern": "^AC-AE-(00[1-9]|01[0-6])$"
    },
    "caseId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "revision": {
      "type": "string",
      "minLength": 1
    },
    "runnerRevision": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{7,64}$"
    },
    "executionMode": {
      "const": "real"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "origin",
        "adapterId"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "origin": {
          "type": "string",
          "minLength": 1
        },
        "adapterId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodeVersion",
        "platform",
        "arch"
      ],
      "properties": {
        "nodeVersion": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "arch": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "configDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "corpusId",
        "version",
        "sha256",
        "targetRevision",
        "caseConfigDigest"
      ],
      "properties": {
        "corpusId": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "targetRevision": {
          "type": "string",
          "minLength": 1
        },
        "caseConfigDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome"
      ],
      "properties": {
        "outcome": {
          "enum": [
            "passed",
            "failed",
            "partial",
            "error"
          ]
        }
      }
    },
    "actual": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "terminationReason",
        "exitCode"
      ],
      "properties": {
        "outcome": {
          "enum": [
            "passed",
            "failed",
            "partial",
            "error"
          ]
        },
        "terminationReason": {
          "type": "string",
          "minLength": 1
        },
        "exitCode": {
          "enum": [
            0,
            1,
            2
          ]
        }
      }
    },
    "oracleResultRefs": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "$ref": "https://quality-harness.dev/schemas/hate/v1/artifact-manifest.schema.json#/properties/artifacts/items"
      }
    },
    "artifactRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://quality-harness.dev/schemas/hate/v1/artifact-manifest.schema.json#/properties/artifacts/items"
      }
    },
    "verdict": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "ineligibilityReason": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "qegHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "verdictGeneratedByLakda"
      ],
      "properties": {
        "status": {
          "const": "pending_external"
        },
        "verdictGeneratedByLakda": {
          "const": false
        }
      }
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    }
  }
}

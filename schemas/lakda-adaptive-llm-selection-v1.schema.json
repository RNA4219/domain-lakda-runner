{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/lakda/adaptive-llm-selection/v1",
  "title": "Lakda adaptive LLM selection",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "decision", "candidateId"],
      "properties": {
        "schemaVersion": { "const": "lakda/adaptive-llm-selection/v1" },
        "decision": { "const": "action" },
        "candidateId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "decision"],
      "properties": {
        "schemaVersion": { "const": "lakda/adaptive-llm-selection/v1" },
        "decision": { "const": "stop" }
      }
    }
  ]
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/lakda/target-manifest/v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "manifestId", "targetClass", "status", "owner", "environment", "access", "scope", "safety", "privacy", "actionContracts", "settleProfile", "acceptance"],
  "properties": {
    "schemaVersion": {"const": "lakda/target-manifest/v1"},
    "manifestId": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$"},
    "targetClass": {"enum": ["crm-list", "commerce-card", "collaboration-workspace"]},
    "status": {"enum": ["pending_external", "ready"]},
    "owner": {"type": "string", "minLength": 1},
    "environment": {"type": "object", "additionalProperties": false, "required": ["name", "baseUrlOrigin"], "properties": {"name": {"const": "staging"}, "baseUrlOrigin": {"type": ["string", "null"]}}},
    "access": {"type": "object", "additionalProperties": false, "required": ["approved", "authSource", "approvalEvidenceRef"], "properties": {"approved": {"type": "boolean"}, "authSource": {"enum": ["pending_external", "github-environment", "local-auth-state", "none"]}, "approvalEvidenceRef": {"type": "string", "minLength": 1}}},
    "scope": {"type": "object", "additionalProperties": false, "required": ["allowHosts", "pathPrefixes"], "properties": {"allowHosts": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "pathPrefixes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^/"}}}},
    "safety": {"type": "object", "additionalProperties": false, "required": ["allowMutationKinds", "resetProcedureRef", "killSwitchRef"], "properties": {"allowMutationKinds": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["none", "create", "update", "delete", "purchase", "publish", "external-message", "credential-change", "parameter-mutation", "skip", "reorder", "double-execution", "race", "unknown"]}}, "resetProcedureRef": {"type": "string", "minLength": 1}, "killSwitchRef": {"type": "string", "minLength": 1}}},
    "privacy": {"type": "object", "additionalProperties": false, "required": ["piiPolicyRef", "sensitiveValuesPersisted"], "properties": {"piiPolicyRef": {"type": "string", "minLength": 1}, "sensitiveValuesPersisted": {"const": false}}},
    "actionContracts": {"type": "array", "uniqueItems": true, "items": {"type": "object", "additionalProperties": false, "required": ["actionId", "mutationKind"], "properties": {"actionId": {"type": "string", "minLength": 1}, "mutationKind": {"type": "string", "minLength": 1}}}},
    "settleProfile": {"type": "object", "additionalProperties": false, "required": ["policyVersion", "networkQuietExclusions"], "properties": {"policyVersion": {"enum": ["lightweight-dom/v1", "consensus/v1"]}, "readiness": {"type": ["object", "null"]}, "networkQuietExclusions": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^/"}}}},
    "acceptance": {"type": "object", "additionalProperties": false, "required": ["p0ActionIds", "p1ActionIds"], "properties": {"p0ActionIds": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}, "p1ActionIds": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}}
  },
  "allOf": [{"if": {"properties": {"status": {"const": "ready"}}}, "then": {"properties": {"environment": {"properties": {"baseUrlOrigin": {"type": "string", "pattern": "^https://[^/?#]+$"}}}, "access": {"properties": {"approved": {"const": true}, "authSource": {"enum": ["github-environment", "local-auth-state", "none"]}}}, "scope": {"properties": {"allowHosts": {"minItems": 1}}}, "actionContracts": {"minItems": 1}, "acceptance": {"properties": {"p0ActionIds": {"minItems": 1}}}}}}]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lakda.dev/schemas/adaptive-acceptance-suite-index-v1.schema.json",
  "title": "Lakda adaptive acceptance suite index v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "suiteId",
    "version",
    "reports"
  ],
  "properties": {
    "schemaVersion": {
      "const": "lakda/adaptive-acceptance-suite-index/v1"
    },
    "suiteId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "reports": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\\\.\\\\.(?:/|$))[A-Za-z0-9._/-]+$"
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/lakda/v1/config.schema.json",
  "title": "Lakda v1 configuration",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "locator": { "type": "object", "additionalProperties": false, "properties": { "testId": { "type": "string", "minLength": 1 }, "role": { "enum": ["button", "link", "textbox", "checkbox", "combobox", "option", "menuitem", "tab"] }, "name": { "type": "string", "minLength": 1 } } },
    "action": { "type": "object", "additionalProperties": false, "required": ["id", "kind"], "properties": { "id": { "type": "string", "minLength": 1 }, "kind": { "enum": ["navigate", "goto", "click", "fill", "check", "select", "press"] }, "path": { "type": "string" }, "locator": { "$ref": "#/definitions/locator" }, "selector": { "type": "string" }, "value": { "type": "string" }, "accessibleName": { "type": "string" }, "inputProfileId": { "type": "string", "minLength": 1 }, "key": { "enum": ["Enter", "Escape", "Space", "Tab"] }, "mutates": { "type": "boolean" } } }
  },
  "properties": {
    "schemaVersion": { "const": "lakda/v1" },
    "baseUrl": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["smoke", "seeded-random", "regression-replay", "llm-explore"] },
    "browser": { "const": "chromium" },
    "seed": { "type": "integer" },
    "persona": { "type": "string", "minLength": 1 },
    "durationMs": { "type": "integer", "minimum": 1 },
    "maxActions": { "type": "integer", "minimum": 1 },
    "workers": { "type": "integer", "minimum": 1, "maximum": 4 },
    "outputDir": { "type": "string", "minLength": 1 },
    "headed": { "type": "boolean" },
    "actionCatalog": { "type": "array", "items": { "$ref": "#/definitions/action" } },
    "candidates": { "type": "array", "items": { "$ref": "#/definitions/action" } },
    "inputProfiles": { "type": "object", "additionalProperties": { "type": "string" } },
    "profiles": { "type": "object", "additionalProperties": false, "properties": { "smoke": { "type": "object", "additionalProperties": false, "required": ["actionIds"], "properties": { "actionIds": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } } } }, "seededRandom": { "type": "object", "additionalProperties": false, "properties": { "candidateIds": { "type": "array", "items": { "type": "string", "minLength": 1 } }, "count": { "type": "integer", "minimum": 1 } } } } },
    "classifier": { "type": "object", "additionalProperties": false, "properties": { "majorRequestUrlPatterns": { "type": "array", "items": { "type": "string" } }, "consoleErrorAllowPatterns": { "type": "array", "items": { "type": "string" } } } },
    "personas": { "type": "object", "additionalProperties": { "type": "object", "additionalProperties": false, "properties": { "storageStatePath": { "type": "string" }, "validationPath": { "type": "string" }, "loginUrlPattern": { "type": "string" }, "requiredLocator": { "$ref": "#/definitions/locator" } } } },
    "obligations": { "type": "array", "items": { "type": "object", "additionalProperties": false, "properties": { "expectedUrl": { "type": "string" }, "visible": { "$ref": "#/definitions/locator" } } } },
    "fixtureReset": { "type": "object", "additionalProperties": false, "required": ["url"], "properties": { "url": { "type": "string", "minLength": 1 } } },
    "safety": { "type": "object", "additionalProperties": false, "properties": { "allowHosts": { "type": "array", "items": { "type": "string" } }, "denyActionKinds": { "type": "array", "items": { "type": "string" } }, "maxActionsPerMinute": { "type": "integer", "minimum": 1 }, "requireFixtureResetForMutations": { "type": "boolean" }, "fixtureResetConfigured": { "type": "boolean" } } },
    "llm": { "type": "object", "additionalProperties": false, "properties": { "enabled": { "type": "boolean" }, "baseUrl": { "type": "string" }, "expectedModelId": { "type": "string" }, "modelSha256": { "type": "string" }, "modelPath": { "type": "string" }, "runtimeEvidence": { "type": "object", "additionalProperties": false, "properties": { "runtimeVersion": { "type": "string" }, "runtimeBuild": { "type": "string" }, "chatTemplateHash": { "type": "string" } } }, "seed": { "type": "integer" }, "temperature": { "type": "number" }, "topP": { "type": "number" }, "maxTokens": { "type": "integer" }, "connectTimeoutMs": { "type": "integer" }, "requestTimeoutMs": { "type": "integer" }, "maxRetries": { "type": "integer", "minimum": 0, "maximum": 2 } } },
    "artifacts": { "type": "object", "additionalProperties": false, "properties": { "classification": { "enum": ["public", "internal", "confidential", "restricted"] }, "trace": { "const": "retain-on-non-pass" }, "screenshot": { "const": "retain-on-non-pass" }, "video": { "type": "boolean" }, "har": { "type": "boolean" }, "domSnapshots": { "type": "boolean" }, "maxRunBytes": { "type": "integer", "minimum": 1 } } }
  }
}
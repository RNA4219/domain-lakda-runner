{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/lakda/v1/manual-bb-release-record.schema.json",
  "title": "Lakda manual black-box release evidence",
  "type": "object",
  "required": ["schemaVersion", "subjectRevision", "testExecutionMode", "operator", "startedAt", "completedAt", "environment", "security", "files", "recordPayloadSha256"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {"const": "lakda/manual-bb-release/v1"},
    "subjectRevision": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
    "testExecutionMode": {"const": "real"},
    "operator": {"type": "string", "minLength": 1},
    "startedAt": {"type": "string", "format": "date-time"},
    "completedAt": {"type": "string", "format": "date-time"},
    "environment": {
      "type": "object",
      "required": ["name", "baseUrlOrigin", "allowHosts", "authSource"],
      "additionalProperties": false,
      "properties": {
        "name": {"const": "staging"},
        "baseUrlOrigin": {"type": "string", "pattern": "^https://[^/?#]+$"},
        "allowHosts": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "authSource": {"enum": ["github-environment", "local-auth-state", "none"]}
      }
    },
    "security": {
      "type": "object",
      "required": ["credentialsPersisted", "sensitiveValuesPersisted"],
      "additionalProperties": false,
      "properties": {
        "credentialsPersisted": {"const": false},
        "sensitiveValuesPersisted": {"const": false}
      }
    },
    "files": {
      "type": "object",
      "required": ["caseSet", "gateDecision", "executions"],
      "additionalProperties": false,
      "properties": {
        "caseSet": {"$ref": "#/$defs/file"},
        "gateDecision": {"$ref": "#/$defs/file"},
        "executions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/file"}}
      }
    },
    "recordPayloadSha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "file": {
      "type": "object",
      "required": ["path", "size", "sha256"],
      "additionalProperties": false,
      "properties": {
        "path": {"type": "string", "minLength": 1, "pattern": "^(?![A-Za-z]:|/|.*(?:^|[\\/])\\.\\.(?:[\\/]|$)).+$"},
        "size": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
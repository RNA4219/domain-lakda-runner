{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/lakda/adaptive-contracts/v1.schema.json",
  "oneOf": [
    { "$ref": "#/$defs/observation" }, { "$ref": "#/$defs/fingerprint" }, { "$ref": "#/$defs/candidate" }, { "$ref": "#/$defs/execution" },
    { "$ref": "#/$defs/oracle" }, { "$ref": "#/$defs/evidence" }, { "$ref": "#/$defs/capabilities" }, { "$ref": "#/$defs/error" }
  ],
  "$defs": {
    "version": { "const": "lakda/adaptive-contracts/v1" },
    "target": { "type": "object", "additionalProperties": false, "required": ["targetId", "kind"], "properties": { "targetId": { "type": "string", "minLength": 1 }, "kind": { "enum": ["page", "frame", "dialog", "device", "surface", "http"] }, "contextId": { "type": "string" }, "parentTargetId": { "type": "string" }, "framePath": { "type": "array", "items": { "type": "string" } }, "origin": { "type": "string" }, "lifecycle": { "enum": ["active", "closed", "lost"] } } },
    "evidence": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "artifactId", "path", "sha256", "size", "classification", "redactionStatus", "securityStatus"], "properties": { "schemaVersion": { "$ref": "#/$defs/version" }, "artifactId": { "type": "string", "minLength": 1 }, "path": { "type": "string", "minLength": 1 }, "sha256": { "type": "string", "minLength": 32 }, "size": { "type": "integer", "minimum": 0 }, "classification": { "enum": ["public", "internal", "confidential", "restricted"] }, "redactionStatus": { "enum": ["not_required", "redacted", "pending", "failed"] }, "securityStatus": { "enum": ["pass", "fail", "not_applicable"] }, "hateEntryRef": { "type": "string" } } },
    "observation": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "observationId", "observedAt", "targetRef", "completeness", "ui", "forms", "dialogs", "topology", "obligations", "provenance"], "properties": { "schemaVersion": { "$ref": "#/$defs/version" }, "observationId": { "type": "string", "minLength": 1 }, "observedAt": { "type": "string", "minLength": 1 }, "targetRef": { "$ref": "#/$defs/target" }, "completeness": { "enum": ["complete", "partial", "unavailable"] }, "url": { "type": "string" }, "personaRef": { "type": "string" }, "ui": { "type": "object" }, "forms": { "type": "array" }, "dialogs": { "type": "array" }, "topology": { "type": "object" }, "networkSummary": { "type": "array" }, "obligations": { "type": "object", "additionalProperties": { "enum": ["met", "unmet", "unknown"] } }, "provenance": { "type": "object" }, "adapterDataRef": { "type": "string" } } },
    "fingerprint": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "algorithmVersion", "canonicalizationVersion", "value", "observationDigest", "componentSummary"], "properties": { "schemaVersion": { "$ref": "#/$defs/version" }, "algorithmVersion": { "type": "string" }, "canonicalizationVersion": { "type": "string" }, "value": { "type": "string" }, "observationDigest": { "type": "string" }, "componentSummary": { "type": "object" } } },
    "candidate": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "candidateId", "adapterId", "targetRef", "sourceFingerprint", "actionKind", "locatorRecipe", "generatedBy", "risk", "mutationKind"], "properties": { "schemaVersion": { "$ref": "#/$defs/version" }, "candidateId": { "type": "string" }, "adapterId": { "type": "string" }, "targetRef": { "$ref": "#/$defs/target" }, "sourceFingerprint": { "type": "string" }, "actionKind": { "type": "string" }, "locatorRecipe": { "type": "object" }, "inputProfileRef": { "type": "string" }, "generatedBy": { "type": "object" }, "risk": { "type": "object" }, "mutationKind": { "type": "string" }, "mutationClassification": { "type": "object", "additionalProperties": false, "required": ["source", "ruleId"], "properties": { "source": { "enum": ["mechanical", "action-contract", "heuristic", "unknown", "conflict"] }, "ruleId": { "type": "string", "minLength": 1 }, "actionId": { "type": "string", "minLength": 1 } } }, "contract": { "type": "object", "properties": { "enabledWhen": { "type": "object" }, "ensures": { "type": "object" }, "invariants": { "type": "object" }, "dialog": { "type": "object", "additionalProperties": false, "required": ["handling"], "properties": { "handling": { "enum": ["dismiss", "hold", "accept"] }, "messagePattern": { "type": "string" }, "types": { "type": "array", "items": { "type": "string" } } } }, "requirementRefs": { "type": "array", "items": { "type": "string" } } } } } },
    "execution": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "executionId", "candidateId", "preFingerprint", "startedAt", "endedAt", "status", "recoveryStatus", "targetChanges", "settleResult", "evidenceRefs"], "properties": { "schemaVersion": { "$ref": "#/$defs/version" }, "executionId": { "type": "string" }, "candidateId": { "type": "string" }, "preFingerprint": { "type": "string" }, "postFingerprint": { "type": "string" }, "startedAt": { "type": "string" }, "endedAt": { "type": "string" }, "status": { "enum": ["executed", "denied", "unsupported", "timeout", "target_lost", "action_failed", "infrastructure_error"] }, "failureSignature": { "type": "string" }, "recoveryStatus": { "enum": ["not_required", "recovered", "not_recovered", "not_attempted"] }, "targetChanges": { "type": "array" }, "settleResult": { "type": "object" }, "evidenceRefs": { "type": "array", "items": { "$ref": "#/$defs/evidence" } } } },
    "oracle": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "oracleId", "oracleClass", "verdict", "severity", "sourceRefs", "requirementRefs", "evidenceRefs", "message"], "properties": { "schemaVersion": { "$ref": "#/$defs/version" }, "oracleId": { "type": "string" }, "oracleClass": { "enum": ["generic", "product", "security"] }, "verdict": { "enum": ["pass", "fail", "inconclusive", "candidate", "confirmed"] }, "severity": { "enum": ["info", "warning", "major", "critical"] }, "sourceRefs": { "type": "array", "items": { "type": "string" } }, "requirementRefs": { "type": "array", "items": { "type": "string" } }, "evidenceRefs": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }, "message": { "type": "string" } } },
    "capabilities": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "adapterId", "revision", "targetKinds", "actionKinds", "observationCapabilities", "evidenceCapabilities", "recoveryStrategies"], "properties": { "schemaVersion": { "$ref": "#/$defs/version" }, "adapterId": { "type": "string" }, "revision": { "type": "string" }, "targetKinds": { "type": "array", "items": { "type": "string" } }, "actionKinds": { "type": "array", "items": { "type": "string" } }, "observationCapabilities": { "type": "array", "items": { "type": "string" } }, "evidenceCapabilities": { "type": "array", "items": { "type": "string" } }, "recoveryStrategies": { "type": "array", "items": { "type": "string" } } } },
    "error": { "type": "object", "additionalProperties": false, "required": ["schemaVersion", "adapterId", "category", "messageRef", "retryable"], "properties": { "schemaVersion": { "$ref": "#/$defs/version" }, "adapterId": { "type": "string" }, "category": { "enum": ["unsupported", "denied", "timeout", "target_lost", "action_failed", "infrastructure_error"] }, "messageRef": { "type": "string" }, "originalErrorRef": { "type": "string" }, "retryable": { "type": "boolean" } } }
  }
}

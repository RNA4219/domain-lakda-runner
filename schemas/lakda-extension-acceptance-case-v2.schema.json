{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/lakda/extension-acceptance-case/v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "acceptanceId", "caseId", "runId", "attempt", "revision", "configDigest",
    "executionMode", "environment", "corpus", "targetManifest", "expected", "actual",
    "oracleResultRefs", "hateArtifactRefs", "artifactManifestPath", "candidateAudit",
    "verdict", "qegHandoff", "generatedAt"
  ],
  "$defs": {
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "size": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "properties": {
    "schemaVersion": { "const": "lakda/extension-acceptance-case/v2" },
    "acceptanceId": { "const": "AC-LX-014" },
    "caseId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "runId": { "type": "string", "minLength": 1 },
    "attempt": { "type": "integer", "minimum": 1 },
    "revision": { "type": "string", "minLength": 1 },
    "configDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "executionMode": { "const": "real" },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "origin", "adapterId"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "origin": { "type": "string", "format": "uri" },
        "adapterId": { "type": "string", "minLength": 1 }
      }
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpusId", "version", "sha256", "targetRevision", "caseConfigDigest"],
      "properties": {
        "corpusId": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "targetRevision": { "type": "string", "minLength": 1 },
        "caseConfigDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "targetManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifestId", "sha256"],
      "properties": {
        "manifestId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
        "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome"],
      "properties": { "outcome": { "enum": ["passed", "failed", "partial", "error"] } }
    },
    "actual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "terminationReason", "exitCode"],
      "properties": {
        "outcome": { "enum": ["passed", "failed", "partial", "error"] },
        "terminationReason": { "type": "string", "minLength": 1 },
        "exitCode": { "type": "integer" }
      }
    },
    "oracleResultRefs": { "type": "array", "items": { "$ref": "#/$defs/artifactRef" } },
    "hateArtifactRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/artifactRef" } },
    "artifactManifestPath": { "type": "string", "minLength": 1 },
    "candidateAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion", "snapshotCount", "observedControls", "classifiedControls",
        "unclassifiedControls", "candidateCount", "coverageDebtCount", "debtByReason",
        "requiredActionIds", "observedActionIds", "debtActionIds", "eligible", "violations"
      ],
      "properties": {
        "schemaVersion": { "const": "lakda/target-candidate-audit/v1" },
        "snapshotCount": { "type": "integer", "minimum": 0 },
        "observedControls": { "type": "integer", "minimum": 0 },
        "classifiedControls": { "type": "integer", "minimum": 0 },
        "unclassifiedControls": { "type": "integer", "minimum": 0 },
        "candidateCount": { "type": "integer", "minimum": 0 },
        "coverageDebtCount": { "type": "integer", "minimum": 0 },
        "debtByReason": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "requiredActionIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "observedActionIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "debtActionIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
        "eligible": { "type": "boolean" },
        "violations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "verdict": { "enum": ["passed", "failed"] },
    "qegHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "verdictGeneratedByLakda"],
      "properties": {
        "status": { "const": "pending_external" },
        "verdictGeneratedByLakda": { "const": false }
      }
    },
    "generatedAt": { "type": "string", "format": "date-time" }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lakda.dev/schemas/adaptive-acceptance-corpus-v1.schema.json",
  "title": "Lakda adaptive acceptance corpus v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "corpusId",
    "version",
    "targetRevision",
    "cases"
  ],
  "properties": {
    "schemaVersion": {
      "const": "lakda/adaptive-acceptance-corpus/v1"
    },
    "corpusId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "targetRevision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "caseId",
        "acceptanceId",
        "configDigest",
        "expected"
      ],
      "properties": {
        "caseId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$"
        },
        "acceptanceId": {
          "type": "string",
          "pattern": "^AC-AE-(00[1-9]|01[0-6])$"
        },
        "configDigest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "outcome"
          ],
          "properties": {
            "outcome": {
              "enum": [
                "passed",
                "failed",
                "partial",
                "error"
              ]
            }
          }
        }
      }
    }
  }
}

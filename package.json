{
  "name": "domain-lakda-runner",
  "version": "0.4.0-rc.2",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "examples",
    "vendor/hate/v1/artifact-manifest.schema.json",
    "README.md",
    "RUNBOOK.md",
    "CHANGELOG.md",
    "LICENSE",
    "LICENSE.ja.md",
    "NOTICE",
    "LICENSING.md",
    "COMMERCIAL-LICENSE.md",
    "THIRD_PARTY_NOTICES.md",
    "vendor/hate/LICENSE"
  ],
  "type": "module",
  "engines": {
    "node": "24.6.0",
    "npm": "11.5.1"
  },
  "bin": {
    "lakda": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check:docs": "node scripts/check-docs.mjs",
    "test": "playwright test --workers=1",
    "test:parallel": "playwright test",
    "test:headed": "playwright test tests/headed.spec.ts --headed",
    "smoke:external": "npm run build && node scripts/run-external-smoke.mjs",
    "check": "npm run check:docs && npm run typecheck && npm run lint && npm run build && npm test",
    "pack:check": "npm run build && node scripts/check-package-contents.mjs && node scripts/check-package-install.mjs",
    "acceptance:fixture": "npm run build && node scripts/run-acceptance.mjs",
    "acceptance:adaptive": "npm run build && npx playwright test tests/adaptive",
    "acceptance:adaptive:real": "npm run build && node scripts/run-adaptive-real-acceptance.mjs",
    "acceptance:adaptive:verify-real": "node scripts/verify-adaptive-real-acceptance.mjs",
    "acceptance:extension:real": "npm run build && node scripts/run-lakda-extension-real-acceptance.mjs",
    "acceptance:extension:verify-real": "node scripts/verify-lakda-extension-real-acceptance.mjs",
    "acceptance:real-llm": "npm run acceptance:real-llm:full",
    "check:hate": "node scripts/check-hate-upstream.mjs",
    "acceptance:real-llm:full": "npm run build && node scripts/run-real-llm-acceptance.mjs --profile=full",
    "acceptance:real-llm:worker-smoke": "npm run build && node scripts/run-real-llm-acceptance.mjs --profile=worker-smoke",
    "acceptance:verify": "npm run build && node scripts/verify-real-llm-acceptance.mjs",
    "check:hate:upstream": "node scripts/check-hate-upstream.mjs --require-upstream",
    "check:ctg-triage": "node scripts/check-ctg-triage.mjs",
    "coverage:v8-to-lcov": "node scripts/v8-coverage-to-lcov.mjs",
    "release:prepare-hate": "node scripts/prepare-hate-rc-input.mjs",
    "release:prepare-gate": "npm run build && node scripts/prepare-release-gate.mjs",
    "release:prepare-rand": "npm run build && node scripts/prepare-rand-release-summary.mjs",
    "release:prepare-reference-staging": "npm run build && node scripts/prepare-reference-staging-summary.mjs",
    "release:scan-evidence": "npm run build && node scripts/scan-release-evidence.mjs",
    "release:scan-package": "npm run build && node scripts/scan-release-package.mjs",
    "release:validate-profile": "node scripts/validate-release-profile.mjs",
    "test:contracts": "playwright test --workers=1 tests/adaptive/acceptance-common.spec.ts tests/adaptive/registries.spec.ts tests/adaptive/llm-select.spec.ts tests/runs.spec.ts tests/schema-catalog.spec.ts tests/release-profile.spec.ts",
    "test:examples": "playwright test --workers=1 tests/examples.spec.ts"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "playwright": "1.61.1"
  },
  "license": "SEE LICENSE IN LICENSE"
}

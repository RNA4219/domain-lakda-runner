{
  "name": "domain-lakda-runner",
  "version": "0.2.1",
  "private": true,
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "engines": {
    "node": "24.6.0",
    "npm": "11.5.1"
  },
  "bin": {
    "lakda": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check:docs": "node scripts/check-docs.mjs",
    "test": "playwright test",
    "test:headed": "playwright test tests/headed.spec.ts --headed",
    "smoke:external": "npm run build && node scripts/run-external-smoke.mjs",
    "check": "npm run check:docs && npm run typecheck && npm run lint && npm run build && npm test",
    "pack:check": "npm pack --dry-run",
    "acceptance:fixture": "npm run build && node scripts/run-acceptance.mjs",
    "acceptance:real-llm": "npm run acceptance:real-llm:full",
    "check:hate": "node scripts/check-hate-upstream.mjs",
    "acceptance:real-llm:full": "npm run build && node scripts/run-real-llm-acceptance.mjs --profile=full",
    "acceptance:real-llm:worker-smoke": "npm run build && node scripts/run-real-llm-acceptance.mjs --profile=worker-smoke",
    "acceptance:verify": "npm run build && node scripts/verify-real-llm-acceptance.mjs",
    "check:hate:upstream": "node scripts/check-hate-upstream.mjs --require-upstream",
    "check:ctg-triage": "node scripts/check-ctg-triage.mjs",
    "coverage:v8-to-lcov": "node scripts/v8-coverage-to-lcov.mjs",
    "release:prepare-hate": "node scripts/prepare-hate-rc-input.mjs",
    "release:prepare-gate": "npm run build && node scripts/prepare-release-gate.mjs",
    "release:scan-evidence": "npm run build && node scripts/scan-release-evidence.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "playwright": "1.61.1"
  }
}
